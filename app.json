{
  "name": "fana-aibot",
  "description": "Advanced WhatsApp Bot with AI capabilities, command system, and automation features",
  "repository": "https://github.com/NjabuloJf/fana-aibot",
  "logo": "https://i.imgur.com/fana-logo.png",
  "keywords": [
    "whatsapp",
    "bot",
    "ai",
    "automation",
    "baileys",
    "nodejs",
    "fana",
    "chatbot"
  ],
  "image": "heroku/nodejs",
  "stack": "heroku-22",
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    },
    {
      "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest"
    },
    {
      "url": "https://github.com/DuckyTeam/heroku-buildpack-imagemagick"
    }
  ],
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "addons": [
    {
      "plan": "heroku-postgresql:mini"
    }
  ],
  "env": {
    "BOT_NAME": {
      "description": "Name of your WhatsApp bot",
      "value": "Fana AI Bot",
      "required": false
    },
    "OWNER_NAME": {
      "description": "Bot owner name",
      "value": "Fana AI",
      "required": false
    },
    "OWNER_NUMBER": {
      "description": "Bot owner WhatsApp number (without +)",
      "value": "1234567890",
      "required": true
    },
    "PREFIX": {
      "description": "Bot command prefix",
      "value": ".",
      "required": false
    },
    "AUTO_VIEW_STATUS": {
      "description": "Auto view WhatsApp status",
      "value": "true",
      "required": false
    },
    "AUTO_LIKE_STATUS": {
      "description": "Auto like WhatsApp status",
      "value": "true",
      "required": false
    },
    "AUTO_TYPING": {
      "description": "Auto typing indicator",
      "value": "true",
      "required": false
    },
    "AUTO_WELCOME": {
      "description": "Auto welcome new members",
      "value": "true",
      "required": false
    },
    "AUTO_ANTILINK": {
      "description": "Auto antilink protection",
      "value": "true",
      "required": false
    },
    "AUTO_JOIN_GROUP": {
      "description": "Auto join groups after pairing",
      "value": "true",
      "required": false
    },
    "AUTO_JOIN_CHANNEL": {
      "description": "Auto join channels after pairing",
      "value": "true",
      "required": false
    },
    "CHANNEL_LINK": {
      "description": "Your WhatsApp channel link",
      "value": "https://whatsapp.com/channel/0029VaAkETLLY6d8qhLmZt2v",
      "required": false
    },
    "BOT_VERSION": {
      "description": "Bot version",
      "value": "1.0.0",
      "required": false
    },
    "BOT_FOOTER": {
      "description": "Bot footer message",
      "value": "© 2024 Fana AI Bot - Powered by AI",
      "required": false
    },
    "PORT": {
      "description": "Port for web server",
      "value": "3000",
      "required": false
    },
    "TIMEZONE": {
      "description": "Bot timezone",
      "value": "Asia/Jakarta",
      "required": false
    },
    "OPENAI_API_KEY": {
      "description": "OpenAI API key for ChatGPT features (optional)",
      "value": "",
      "required": false
    },
    "GOOGLE_API_KEY": {
      "description": "Google API key for search features (optional)",
      "value": "",
      "required": false
    },
    "YOUTUBE_API_KEY": {
      "description": "YouTube API key for video features (optional)",
      "value": "",
      "required": false
    },
    "WEATHER_API_KEY": {
      "description": "Weather API key (optional)",
      "value": "",
      "required": false
    },
    "NEWS_API_KEY": {
      "description": "News API key (optional)",
      "value": "",
      "required": false
    },
    "GEMINI_API_KEY": {
      "description": "Google Gemini API key (optional)",
      "value": "",
      "required": false
    },
    "AUDD_API_KEY": {
      "description": "AudD API key for Shazam feature (optional)",
      "value": "",
      "required": false
    },
    "DATABASE_URL": {
      "description": "Database URL (auto-generated by Heroku)",
      "required": false
    },
    "SESSION_SECRET": {
      "description": "Session secret key",
      "generator": "secret",
      "required": false
    },
    "NODE_ENV": {
      "description": "Node environment",
      "value": "production",
      "required": false
    },
    "LOG_LEVEL": {
      "description": "Logging level",
      "value": "info",
      "required": false
    },
    "MAX_FILE_SIZE": {
      "description": "Maximum file size in MB",
      "value": "50",
      "required": false
    },
    "RATE_LIMIT": {
      "description": "Rate limit per minute",
      "value": "10",
      "required": false
    },
    "AUTO_UPDATE_BOT": {
      "description": "Auto update bot code",
      "value": "true",
      "required": false
    },
    "AUTO_BACKUP": {
      "description": "Auto backup data",
      "value": "true",
      "required": false
    },
    "BACKUP_INTERVAL": {
      "description": "Backup interval in hours",
      "value": "24",
      "required": false
    },
    "FEATURE_AI_CHAT": {
      "description": "Enable AI chat features",
      "value": "true",
      "required": false
    },
    "FEATURE_MUSIC_DOWNLOAD": {
      "description": "Enable music download",
      "value": "true",
      "required": false
    },
    "FEATURE_VIDEO_DOWNLOAD": {
      "description": "Enable video download",
      "value": "true",
      "required": false
    },
    "FEATURE_STICKER_MAKER": {
      "description": "Enable sticker maker",
      "value": "true",
      "required": false
    },
    "FEATURE_WEATHER": {
      "description": "Enable weather commands",
      "value": "true",
      "required": false
    },
    "FEATURE_NEWS": {
      "description": "Enable news commands",
      "value": "true",
      "required": false
    },
    "FEATURE_TRANSLATE": {
      "description": "Enable translate commands",
      "value": "true",
      "required": false
    },
    "FEATURE_QR_CODE": {
      "description": "Enable QR code features",
      "value": "true",
      "required": false
    },
    "FEATURE_GAMES": {
      "description": "Enable game commands",
      "value": "true",
      "required": false
    },
    "FEATURE_ADMIN_TOOLS": {
      "description": "Enable admin tools",
      "value": "true",
      "required": false
    }
  },
  "scripts": {
    "postdeploy": "npm install && npm start"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "website": "https://fana-ai.com",
  "success_url": "/",
  "environments": {
    "test": {
      "scripts": {
        "test": "npm test"
      }
    }
  }
}
